{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitUI",
  "version": "0.7.1",
  "identifier": "com.gitui.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitUI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzOENERDMwMDlCNEEwRDcKUldUWG9MUUpNTjJNTTRyc0YvQ1lNSjlNVFdicHFBUVpUKytENXA1Y2FzQ29FelM5QW1JVVZ2bjQK",
      "endpoints": [
        "https://github.com/shuai132/GitUI/releases/latest/download/latest.json"
      ]
    }
  }
}
